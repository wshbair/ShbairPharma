{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "server.js",
    "start.js",
    "api/**/*.js",
    "assets/js/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "assets/dist",
    "assets/plugins",
    "release-builds"
  ]
}
