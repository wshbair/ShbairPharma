    }
  },
  "dependencies": {
    "@electron/remote": "^2.0.9",
    "@seald-io/nedb": "^4.0.3",
    "archiver": "^7.0.1",
    "async": "^3.2.4",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.3",
    "dompurify": "^3.2.4",
    "electron-context-menu": "^3.6.1",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.0",
    "express": "^4.21.2",
    "express-rate-limit": "^6.7.0",
    "jquery": "^3.7.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "multer": "^2.0.2",
    "nodemon": "^3.1.14",
    "notiflix": "^3.2.5",
    "print-js": "^1.6.0",
    "sanitize-filename": "^1.6.3",
    "ts-node": "^10.9.2",
    "unzipper": "^0.12.3",
    "validator": "^13.15.23"
  },
  "scripts": {
    "electron": "cross-env NODE_ENV=dev nodemon --exec \"\"electron .\"\"",
    "electron-build": "electron-builder",
    "package-win": "electron-packager . ShbairPharma --overwrite --platform=win32 --arch=x64 --icon=assets/images/shbairpharma.ico --prune=true --out=release-builds --version-string.ProductName=\"ShbairPharma\"",
